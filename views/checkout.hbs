{{#if pageError}}
<div class="row justify-content-md-center mt-40">
  <div class="col-lg-6 text-center">
    <h1 class="h4">Checkout unavailable</h1>
    <p class="text-secondary">{{pageError}}</p>
    <a href="/" class="btn btn-primary mt-3">Back to shop</a>
  </div>
</div>
{{else}}
<div class="row justify-content-md-center">
  <div class="col-lg-7">
    <div class="text-center mt-40">
      <h1>
        Checkout
      </h1>
      <p class="text-secondary mb-0">Stripe Press</p>
      <h5 class="mt-3">{{title}}</h5>
      <p class="text-muted small mb-0">{{author}}</p>
      <hr class="mt-40">
      <p class="mb-1">
        Total due: <strong class="text-dark">${{amountLabel}}</strong>
      </p>
      <p class="small text-muted mb-0">Copies available: <strong>{{stock}}</strong></p>
    </div>

    <div class="card box-shadow mt-40">
      <div class="card-body">
        <div
          id="checkout-config"
          data-publishable-key="{{stripePublishableKey}}"
          data-return-url="{{returnUrl}}"
          data-product-id="{{productId}}"
          data-amount-label="{{amountLabel}}"
        ></div>

        <div id="checkout-step-details">
          <h6 class="text-uppercase text-muted small">Your details</h6>
          <div class="form-group">
            <label for="customerName">Full name</label>
            <input type="text" class="form-control" id="customerName" name="customerName" required autocomplete="name" placeholder="Alex Reader">
          </div>
          <div class="form-group">
            <label for="customerEmail">Email</label>
            <input type="email" class="form-control" id="customerEmail" name="customerEmail" required autocomplete="email" placeholder="you@example.com">
          </div>
          <button type="button" class="btn btn-primary btn-lg btn-block" id="btn-prepare-payment">
            Continue to secure payment
          </button>
        </div>

        <div id="checkout-step-pay" class="d-none">
          <h6 class="text-uppercase text-muted small mt-4">Payment</h6>
          <p class="small text-muted">Card details are collected securely by Stripe. We never see your full card number.</p>
          <div id="payment-element" class="payment-element-box"></div>
          <button type="button" class="btn btn-primary btn-lg btn-block mt-3" id="btn-submit-payment">
            Pay ${{amountLabel}}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
{{/if}}
