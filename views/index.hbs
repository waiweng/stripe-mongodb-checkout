{{#if error}}
<div class="alert alert-danger mt-3" role="alert">
  {{error}}
</div>
{{/if}}
<div class="text-center mt-40">
  <h1>
    Stripe Press Shop
  </h1>
  <p class="text-secondary">
    Select a book to purchase
  </p>
</div>
<div class="mt-40 row">
  {{#each products}}
  <div class="col-md-4 mb-4">
    <div class="card box-shadow h-100">
      <img src="{{imageUrl}}" class="card-img-top book-cover" alt="{{title}}">
      <div class="card-body d-flex flex-column">
        <h5 class="card-title">{{title}}</h5>
        <strong>{{author}}</strong>
        <p class="card-text mt-20 text-muted small">
          {{description}}
        </p>
        <p class="mt-auto mb-2">
          <span class="price-tag">${{priceLabel}}</span>
        </p>
        <p class="small text-muted mb-3">In stock: <strong>{{stock}}</strong></p>
        <a href="/checkout?productId={{id}}" class="btn btn-primary btn-block">Buy now</a>
      </div>
    </div>
  </div>
  {{else}}
  <div class="col-12">
    <p class="text-center text-muted">No books available yet. Run <code>node seed.js</code> after connecting MongoDB.</p>
  </div>
  {{/each}}
</div>
