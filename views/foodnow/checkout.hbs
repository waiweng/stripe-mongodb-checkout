{{#if pageError}}
<div class="row justify-content-md-center mt-40">
  <div class="col-lg-6 text-center">
    <h1 class="h4">Checkout unavailable</h1>
    <p class="text-secondary">{{pageError}}</p>
    <a href="/foodnow" class="btn btn-primary mt-3">Back to FoodNow</a>
  </div>
</div>
{{else}}
<div class="row justify-content-md-center">
  <div class="col-lg-7">
    <div class="text-center mt-40">
      <h1>Checkout</h1>
      <p class="text-secondary mb-0">FoodNow × Malay Kitchen</p>
      <h5 class="mt-3">{{dishName}}</h5>
      <p class="text-muted small mb-0">{{restaurantName}}</p>
      <hr class="mt-40">

      <div class="text-left bg-light p-3 rounded border mb-3">
        <h6 class="text-uppercase text-muted small">Transparent pricing</h6>
        <p class="mb-1">Restaurant receives: <strong>AU${{restaurantReceivesLabel}}</strong></p>
        <p class="mb-1">FoodNow platform fee ({{platformFeePercent}}%): <strong>AU${{platformFeeLabel}}</strong></p>
        <p class="mb-0">You pay: <strong class="text-dark">AU${{amountLabel}}</strong></p>
      </div>
    </div>

    <div class="card box-shadow mt-40">
      <div class="card-body">
        <div
          id="foodnow-checkout-config"
          data-publishable-key="{{stripePublishableKey}}"
          data-return-url="{{returnUrl}}"
          data-menu-item-id="{{menuItemId}}"
        ></div>

        <div id="foodnow-step-details">
          <h6 class="text-uppercase text-muted small">Your details</h6>
          <div class="form-group">
            <label for="foodnowCustomerName">Full name</label>
            <input type="text" class="form-control" id="foodnowCustomerName" name="customerName" required autocomplete="name" placeholder="Aisha Rahman">
          </div>
          <div class="form-group">
            <label for="foodnowCustomerEmail">Email</label>
            <input type="email" class="form-control" id="foodnowCustomerEmail" name="customerEmail" required autocomplete="email" placeholder="you@example.com">
          </div>
          <button type="button" class="btn btn-primary btn-lg btn-block" id="foodnow-btn-prepare">
            Continue to secure payment
          </button>
        </div>

        <div id="foodnow-step-pay" class="d-none">
          <h6 class="text-uppercase text-muted small mt-4">Payment</h6>
          <p class="small text-muted">Card details are collected securely by Stripe. FoodNow never sees your full card number.</p>
          <div id="foodnow-payment-element" class="payment-element-box"></div>
          <button type="button" class="btn btn-primary btn-lg btn-block mt-3" id="foodnow-btn-submit">
            Complete order — AU${{amountLabel}}
          </button>
          <p class="small text-muted text-center mt-3 mb-0">Secured by Stripe</p>
        </div>
      </div>
    </div>
  </div>
</div>
{{/if}}
