{{#if error}}
<div class="row justify-content-md-center mt-40">
  <div class="col-lg-8 text-center">
    <p class="text-danger">{{error}}</p>
    <a href="/foodnow" class="btn btn-primary mt-2">Retry</a>
  </div>
</div>
{{else}}
<div class="text-center mt-40">
  <div class="mb-3">
    <span class="badge badge-success align-middle">FoodNow</span>
  </div>
  <h1 class="display-4">Your favourite Malaysian food, delivered fast</h1>
  <p class="lead text-secondary mb-1">Malay Kitchen — Now on FoodNow</p>
</div>

<div class="card border-0 shadow-sm mt-4 mb-4">
  <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between">
    <div>
      <h2 class="h4 mb-1">Malay Kitchen</h2>
      <p class="text-muted mb-0">Authentic Malaysian dishes, prepared fresh.</p>
    </div>
    <span class="badge badge-primary mt-3 mt-md-0">Powered by Stripe Connect</span>
  </div>
</div>

<div class="row">
  {{#each menuItems}}
  <div class="col-md-4 mb-4">
    <div class="card h-100 shadow-sm">
      <img class="card-img-top" src="{{imageUrl}}" alt="{{name}}" style="object-fit: cover; height: 200px;">
      <div class="card-body d-flex flex-column">
        <h3 class="h5 card-title">{{name}}</h3>
        <p class="card-text text-muted small flex-grow-1">{{description}}</p>
        <p class="mb-3"><strong>AU${{priceLabel}}</strong></p>
        <a class="btn btn-primary btn-block mt-auto" href="/foodnow/checkout?menuItemId={{id}}">Order Now</a>
      </div>
    </div>
  </div>
  {{/each}}
</div>

<div class="card bg-light border-0 mt-5 mb-5">
  <div class="card-body text-center py-4">
    <h2 class="h4 mb-2">Subscribe to FoodNow Plus</h2>
    <p class="mb-3 text-secondary">AU$9.90/month — Free delivery on every order</p>
    <a class="btn btn-outline-primary btn-lg" href="/foodnow/subscribe">Subscribe Now</a>
  </div>
</div>
{{/if}}
