STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
PORT=3000

# FoodNow demo (Stripe Connect + Billing)
RESTAURANT_CONNECTED_ACCOUNT_ID=acct_your_connected_account
PLATFORM_FEE_PERCENT=15
# Leave blank to auto-create on first subscription; or set after Stripe creates the Price
FOODNOW_PLUS_PRICE_ID=
# Optional: signing secret for a second webhook endpoint URL pointing at /foodnow/webhook
STRIPE_WEBHOOK_SECRET_FOODNOW=
